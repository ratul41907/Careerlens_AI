# CareerLens AI - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# ============================================
# SECURITY SETTINGS
# ============================================
# Secret key for session management (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Rate limiting (requests per hour)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE_MB=10

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ============================================
# OPTIONAL: AUTHENTICATION
# ============================================
# Enable authentication (true/false)
ENABLE_AUTH=false

# Admin credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/careerlens.log

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CACHING=true
ENABLE_ANALYTICS=false
ENABLE_EMAIL_REPORTS=false